{
  "name": "nv",
  "version": "1.0.0",
  "description": "A keyboard-first Notational Velocity clone for plain-text markdown notes",
  "main": "dist/main.js",
  "scripts": {
    "build": "node build.js",
    "start": "node build.js && electron .",
    "package": "node build.js && electron-builder",
    "test": "tsx --test test/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts test/**/*.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chokidar": "^3.6.0",
    "dompurify": "^3.3.1",
    "marked": "^17.0.3"
  },
  "build": {
    "appId": "com.nv.notes",
    "productName": "NV",
    "directories": {
      "output": "release"
    },
    "electronDist": "node_modules/electron/dist",
    "files": [
      "dist/**/*"
    ],
    "linux": {
      "target": [
        "dir"
      ],
      "category": "Office"
    },
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  },
  "overrides": {
    "minimatch": "^10.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.3.0",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  }
}
