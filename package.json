    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.3.0",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
